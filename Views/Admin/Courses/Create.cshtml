@model OMS.Models.ViewModels.Admin.CourseCreateVm
@{
    var subjects = (IEnumerable<OMS.Models.Entities.Subject>)ViewBag.Subjects;
    var teachers = (IEnumerable<OMS.Models.Entities.User>)ViewBag.Teachers;

    var returnUrl = Context.Request.Path + Context.Request.QueryString;
    var createSubjectUrl = "/admin/subjects/create?returnUrl=" + Uri.EscapeDataString(returnUrl);
    var createTeacherUrl = "/admin/users/create?returnUrl=" + Uri.EscapeDataString(returnUrl) + "&presetRole=teacher";
}

<div class="card">
    <div class="card-body">
        <form method="post" id="courseForm">
            @Html.AntiForgeryToken()

            <div class="form-group">
                <label>Tên khóa học</label>
                <input asp-for="CourseName" class="form-control" placeholder="VD: ASP.NET MVC căn bản" />
                <span class="text-danger" asp-validation-for="CourseName"></span>
            </div>

            <div class="row">
                <div class="col-md-6">
                    <div class="form-group">
                        <div class="d-flex align-items-center justify-content-between mb-2">
                            <label class="mb-0">Môn học</label>
                            <button type="button" class="btn btn-sm btn-outline-primary js-save-draft" data-url="@createSubjectUrl">
                                <i class="fas fa-plus"></i> Tạo môn học
                            </button>
                        </div>

                        <select asp-for="SubjectId" class="form-control select2">
                            <option value="">-- Chọn môn học --</option>
                            @foreach (var s in subjects)
                            {
                                <option value="@s.Subjectid">@s.Subjectname</option>
                            }
                        </select>
                        <span class="text-danger" asp-validation-for="SubjectId"></span>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="form-group">
                        <div class="d-flex align-items-center justify-content-between mb-2">
                            <label class="mb-0">Giảng viên</label>
                            <button type="button" class="btn btn-sm btn-outline-primary js-save-draft" data-url="@createTeacherUrl">
                                <i class="fas fa-plus"></i> Tạo giảng viên
                            </button>
                        </div>

                        <select asp-for="TeacherId" class="form-control select2">
                            <option value="">-- Chọn giảng viên --</option>
                            @foreach (var t in teachers)
                            {
                                <option value="@t.Userid">@t.Fullname (@t.Email)</option>
                            }
                        </select>
                        <span class="text-danger" asp-validation-for="TeacherId"></span>
                    </div>
                </div>
            </div>

            <div class="form-group">
                <label>Mô tả</label>
                <textarea asp-for="Description" class="form-control" rows="4" placeholder="Mô tả khóa học..."></textarea>
            </div>

            <div class="form-check">
                <input asp-for="IsActive" class="form-check-input" />
                <label class="form-check-label">Active</label>
            </div>

            <div class="mt-3">
                <button class="btn btn-brand" type="submit">
                    <i class="fas fa-save"></i> Lưu
                </button>
                <a class="btn btn-ghost ml-2" href="/admin/courses/index">Quay lại</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        $(function () {
            $('.select2').select2({ width: '100%' });

            $('.js-save-draft').on('click', function () {
                const url = $(this).data('url');
                const form = $('#courseForm');
                const token = form.find('input[name="__RequestVerificationToken"]').val();

                const draftForm = $('<form>', { method: 'post', action: '/admin/courses/savedraft' });
                draftForm.append($('<input>', { type: 'hidden', name: '__RequestVerificationToken', value: token }));
                draftForm.append($('<input>', { type: 'hidden', name: 'redirectTo', value: url }));

                draftForm.append($('<input>', { type: 'hidden', name: 'CourseName', value: $('input[name="CourseName"]').val() }));
                draftForm.append($('<input>', { type: 'hidden', name: 'SubjectId', value: $('select[name="SubjectId"]').val() }));
                draftForm.append($('<input>', { type: 'hidden', name: 'TeacherId', value: $('select[name="TeacherId"]').val() }));
                draftForm.append($('<input>', { type: 'hidden', name: 'Description', value: $('textarea[name="Description"]').val() }));
                draftForm.append($('<input>', { type: 'hidden', name: 'IsActive', value: $('input[name="IsActive"]').is(':checked') }));

                $('body').append(draftForm);
                draftForm.submit();
            });
        });
    </script>
}