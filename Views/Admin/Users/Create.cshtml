@model OMS.Models.ViewModels.Admin.UserCreateVm
@{
    var roles = (IEnumerable<OMS.Models.Entities.Role>)ViewBag.Roles;
}

<div class="card">
    <div class="card-body">
        <form method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()

            <div class="row">
                <div class="col-md-8">
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label>Username</label>
                                <input asp-for="Username" class="form-control" />
                                <span class="text-danger" asp-validation-for="Username"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label>Email</label>
                                <input asp-for="Email" class="form-control" />
                                <span class="text-danger" asp-validation-for="Email"></span>
                            </div>
                        </div>
                    </div>

                    <div class="form-group">
                        <label>Họ tên</label>
                        <input asp-for="FullName" class="form-control" />
                        <span class="text-danger" asp-validation-for="FullName"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label>Password</label>
                                <input asp-for="Password" class="form-control" type="password" />
                                <span class="text-danger" asp-validation-for="Password"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label>Role</label>
                                <select asp-for="RoleId" class="form-control select2">
                                    <option value="">-- Chọn role --</option>
                                    @foreach (var r in roles)
                                    {
                                        <option value="@r.Roleid">@r.Rolename</option>
                                    }
                                </select>
                                <span class="text-danger" asp-validation-for="RoleId"></span>
                            </div>
                        </div>
                    </div>

                    <div class="form-check">
                        <input asp-for="IsActive" class="form-check-input" />
                        <label class="form-check-label">Active</label>
                    </div>
                </div>

                <div class="col-md-4">
                    <label>Avatar</label>
                    <div class="mb-2">
                        <img id="avatarPreview"
                             src="https://ui-avatars.com/api/?name=User&background=2563eb&color=fff"
                             style="width:100%;max-width:220px;height:220px;object-fit:cover;border-radius:18px;border:1px solid rgba(0,0,0,.08);" />
                    </div>

                    <div class="form-group">
                        <input asp-for="AvatarFile" type="file" class="form-control" accept="image/*" />
                        <small class="text-muted">Chấp nhận .jpg/.jpeg/.png/.webp, tối đa 2MB</small>
                        <span class="text-danger" asp-validation-for="AvatarFile"></span>
                    </div>
                </div>
            </div>

            <div class="mt-3">
                <button class="btn btn-brand" type="submit">
                    <i class="fas fa-save"></i> Lưu
                </button>
                <a class="btn btn-ghost ml-2" href="/admin/users/index">Quay lại</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        $(function () {
            $('.select2').select2({ width: '100%' });

            const input = document.querySelector('input[name="AvatarFile"]');
            const preview = document.getElementById('avatarPreview');
            if (input) {
                input.addEventListener('change', function () {
                    const file = this.files && this.files[0];
                    if (!file) return;
                    preview.src = URL.createObjectURL(file);
                });
            }
        });
    </script>
}