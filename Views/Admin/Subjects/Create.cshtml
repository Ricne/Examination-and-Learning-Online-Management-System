@model OMS.Models.Entities.Subject
@{
    ViewData["Title"] = ViewData["Title"] ?? "Tạo môn học";
}

<div class="card">
    <div class="card-body">
        <form method="post">
            @Html.AntiForgeryToken()

            <div class="form-group">
                <label>Tên môn học</label>
                <input asp-for="Subjectname" class="form-control" placeholder="VD: Lập trình C#" />
                <span class="text-danger" asp-validation-for="Subjectname"></span>
            </div>

            <div class="form-group">
                <label>Mô tả</label>
                <textarea asp-for="Description" class="form-control" rows="4" placeholder="Mô tả ngắn..."></textarea>
            </div>

            <div class="mt-3">
                <button class="btn btn-brand" type="submit">
                    <i class="fas fa-save"></i> Lưu
                </button>
                <a class="btn btn-ghost ml-2" href="/admin/subjects/index">Quay lại</a>
            </div>
        </form>
    </div>
</div>