@model IEnumerable<dynamic>

<div class="card">
    <div class="card-body">
        <table id="myResultsTable" class="table table-hover">
            <thead>
                <tr>
                    <th style="width:90px;">Attempt</th>
                    <th>Exam</th>
                    <th style="width:180px;">Course</th>
                    <th style="width:130px;">Status</th>
                    <th style="width:150px;">Submit</th>
                    <th style="width:100px;">Score</th>
                    <th style="width:170px;">Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var r in Model)
                {
                    <tr>
                        <td>#@r.Attemptid</td>
                        <td><b>@r.ExamTitle</b></td>
                        <td>@r.CourseName</td>
                        <td>
                            @if ((string)r.Status == "graded")
                            {
                                <span class="badge badge-success">graded</span>
                            }
                            else if ((string)r.Status == "submitted")
                            {
                                <span class="badge badge-warning">submitted</span>
                            }
                            else
                            {
                                <span class="badge badge-secondary">inprogress</span>
                            }
                        </td>
                        <td class="text-muted">
                            @(r.Submittime != null ? ((DateTime)r.Submittime).ToString("yyyy-MM-dd HH:mm") : "-")
                        </td>
                        <td>
                            <span class="badge badge-info">
                                @((r.Finalscore ?? r.Totalscore)?.ToString("0.##") ?? "-")
                            </span>
                        </td>
                        <td>
                            <a class="btn btn-sm btn-outline-primary" href="/student/results/detail?attemptId=@r.Attemptid">
                                <i class="fas fa-eye"></i>
                            </a>

                            @if (r.Allowreview == true)
                            {
                                <a class="btn btn-sm btn-outline-success ml-1" href="/student/review/detail?attemptId=@r.Attemptid">
                                    <i class="fas fa-book-open"></i>
                                </a>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        $(function(){
            $('#myResultsTable').DataTable({
                pageLength: 10,
                order: [[0,'desc']],
                language: {
                    search: "Tìm:",
                    lengthMenu: "Hiện _MENU_ dòng",
                    info: "Trang _PAGE_ / _PAGES_ (Tổng _TOTAL_)",
                    paginate: { previous: "Trước", next: "Sau" }
                }
            });
        });
    </script>
}