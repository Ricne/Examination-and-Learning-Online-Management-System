@{
    Layout = "_PublicLayout";
    ViewData["Title"] = "Home";
}

<div class="public-hero mb-4">
    <div class="d-flex align-items-center mb-2">
        <span class="tile-icon"><i class="fas fa-graduation-cap"></i></span>
        <div class="public-title">Online Learning & Examination System</div>
    </div>

    <div class="public-sub">
        Nền tảng học tập và thi trực tuyến hiện đại, bảo mật, trực quan và dễ dùng.
    </div>

    <div class="mb-2">
        <span class="badge badge-primary"><i class="fas fa-shield-alt mr-1"></i>Secure</span>
        <span class="badge badge-info"><i class="fas fa-chart-line mr-1"></i>Analytics</span>
        <span class="badge badge-warning"><i class="fas fa-random mr-1"></i>Random</span>
    </div>

    <a class="btn btn-brand mt-2" href="/Auth/Login">
        <i class="fas fa-right-to-bracket mr-2"></i> Đăng nhập hệ thống
    </a>
</div>

<div class="row">
    <div class="col-md-6 col-lg-3 mb-3">
        <div class="tile">
            <div class="d-flex align-items-center mb-2">
                <span class="tile-icon"><i class="fas fa-book"></i></span>
                <b>Quản lý khóa học</b>
            </div>
            <div class="text-muted">Tổ chức môn học, khóa học, lesson và theo dõi tiến độ.</div>
        </div>
    </div>

    <div class="col-md-6 col-lg-3 mb-3">
        <div class="tile">
            <div class="d-flex align-items-center mb-2">
                <span class="tile-icon"><i class="fas fa-file-lines"></i></span>
                <b>Ngân hàng câu hỏi</b>
            </div>
            <div class="text-muted">MCQ/True-False/Essay, quản lý đáp án nhanh.</div>
        </div>
    </div>

    <div class="col-md-6 col-lg-3 mb-3">
        <div class="tile">
            <div class="d-flex align-items-center mb-2">
                <span class="tile-icon"><i class="fas fa-robot"></i></span>
                <b>Chấm điểm tự động</b>
            </div>
            <div class="text-muted">Auto-grade trắc nghiệm, hỗ trợ chấm tự luận.</div>
        </div>
    </div>

    <div class="col-md-6 col-lg-3 mb-3">
        <div class="tile">
            <div class="d-flex align-items-center mb-2">
                <span class="tile-icon"><i class="fas fa-chart-pie"></i></span>
                <b>Dashboard</b>
            </div>
            <div class="text-muted">Thống kê course, học viên, completion rate, điểm.</div>
        </div>
    </div>
</div>