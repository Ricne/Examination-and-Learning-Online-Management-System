@model OMS.Models.ViewModels.Auth.LoginVm
@{
    Layout = "_PublicLayout";
    ViewData["Title"] = "Login";
}

<div class="row justify-content-center">
    <div class="col-md-6 col-lg-4">
        <div class="card card-outline card-primary">
            <div class="card-header text-center">
                <span class="h4 font-weight-bold" style="color:#2563eb;">OnlineExam</span>
                <div class="text-muted" style="font-size:.95rem;">Chào mừng quay trở lại</div>
            </div>

            <div class="card-body">
                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger">
                        <i class="fas fa-triangle-exclamation"></i> @TempData["Error"]
                    </div>
                }

                <form asp-action="Login" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="ReturnUrl" />

                    <div class="form-group">
                        <label class="text-muted">Username / Email</label>
                        <div class="input-group">
                            <input asp-for="UsernameOrEmail" class="form-control" placeholder="admin@gmail.com" />
                            <div class="input-group-append">
                                <div class="input-group-text"><span class="fas fa-user"></span></div>
                            </div>
                        </div>
                        <span class="text-danger" asp-validation-for="UsernameOrEmail"></span>
                    </div>

                    <div class="form-group">
                        <label class="text-muted">Password</label>
                        <div class="input-group">
                            <input asp-for="Password" class="form-control" placeholder="••••••••" />
                            <div class="input-group-append">
                                <div class="input-group-text"><span class="fas fa-lock"></span></div>
                            </div>
                        </div>
                        <span class="text-danger" asp-validation-for="Password"></span>
                    </div>

                    <button type="submit" class="btn btn-brand btn-block">
                        <i class="fas fa-right-to-bracket mr-2"></i> Sign in
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>