@model List<OMS.Models.Entities.Examaccesscode>
@{
    var exam = ViewBag.Exam as OMS.Models.Entities.Exam;
    var activeCode = Model.FirstOrDefault(x => x.Isactive == true);
}

@section PageActions {
    <a class="btn btn-outline-secondary" href="/teacher/accesscode/index">
        <i class="fas fa-arrow-left"></i> Back
    </a>
}

<div class="card mb-3">
    <div class="card-body">
        <h5 class="mb-2">@exam?.Title</h5>
        <div class="text-muted">
            Course: <b>@exam?.Course?.Coursename</b>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-lg-5">
        <div class="card">
            <div class="card-header">
                <b>Mã code hiện tại</b>
            </div>
            <div class="card-body text-center">
                @if (activeCode != null)
                {
                    <div style="font-size:36px;font-weight:800;letter-spacing:4px;" class="text-primary mb-3">
                        @activeCode.Accesscode
                    </div>

                    <div class="mb-3">
                        <span class="badge badge-success">ACTIVE</span>
                    </div>

                    <form method="post" action="/teacher/accesscode/close">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="codeId" value="@activeCode.Codeid" />
                        <button class="btn btn-outline-danger" type="submit"
                                onclick="return confirm('Đóng mã code hiện tại?');">
                            <i class="fas fa-lock"></i> Close Code
                        </button>
                    </form>
                }
                else
                {
                    <div class="text-muted mb-3">Chưa có mã code active.</div>
                }

                <form method="post" action="/teacher/accesscode/generate" class="mt-3">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="examId" value="@exam?.Examid" />
                    <button class="btn btn-brand" type="submit">
                        <i class="fas fa-wand-magic-sparkles"></i> Generate New Code
                    </button>
                </form>
            </div>
        </div>
    </div>

    <div class="col-lg-7">
        <div class="card">
            <div class="card-header">
                <b>Lịch sử mã code</b>
            </div>
            <div class="card-body">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th style="width:80px;">ID</th>
                            <th>Code</th>
                            <th style="width:120px;">Status</th>
                            <th style="width:170px;">Created</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="4" class="text-muted">Chưa có mã code nào.</td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var c in Model)
                            {
                                <tr>
                                    <td>@c.Codeid</td>
                                    <td>
                                        <b>@c.Accesscode</b>
                                    </td>
                                    <td>
                                        @if (c.Isactive == true)
                                        {
                                            <span class="badge badge-success">ACTIVE</span>
                                        }
                                        else
                                        {
                                            <span class="badge badge-secondary">CLOSED</span>
                                        }
                                    </td>
                                    <td class="text-muted">
                                        @c.Createdat.ToString("yyyy-MM-dd HH:mm")
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>