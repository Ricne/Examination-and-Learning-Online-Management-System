@model OMS.Models.ViewModels.Teacher.AttemptGradeVm

@section PageActions {
    <a class="btn btn-outline-secondary" href="/teacher/attempts/index">
        <i class="fas fa-arrow-left"></i> Back
    </a>
}

<div class="card mb-3">
    <div class="card-body">
        <h5 class="mb-2">@Model.ExamTitle</h5>
        <div class="text-muted">
            Student: <b>@Model.StudentName</b> |
            Status: <b>@Model.Status</b> |
            Start: <b>@Model.Starttime.ToString("yyyy-MM-dd HH:mm")</b> |
            Submit: <b>@(Model.Submittime.HasValue ? Model.Submittime.Value.ToString("yyyy-MM-dd HH:mm") : "-")</b>
        </div>

        <div class="mt-2">
            <span class="badge badge-dark">Current Total: @(Model.Totalscore?.ToString("0.##") ?? "-")</span>
        </div>
    </div>
</div>

@foreach (var a in Model.Answers)
{
    <div class="card mb-3">
        <div class="card-body">
            <div class="mb-2">
                <span class="badge badge-info text-uppercase">@a.Questiontype</span>
                <span class="badge badge-dark ml-2">@a.Marks điểm</span>
            </div>

            <h6>Câu hỏi</h6>
            <div class="p-3 bg-light rounded mb-3">
                @a.Questioncontent
            </div>

            @if (a.Questiontype == "mcq" || a.Questiontype == "true_false")
            {
                <h6>Đáp án học sinh chọn</h6>
                <div class="mb-3">
                    <span class="badge badge-secondary">@a.SelectedChoiceText</span>
                </div>

                <h6>Điểm</h6>
                <div>
                    <span class="badge badge-success">@(a.Score?.ToString("0.##") ?? "0")</span>
                </div>
            }
            else
            {
                <h6>Bài làm tự luận</h6>
                <div class="p-3 bg-light rounded mb-3" style="white-space:pre-wrap;">
                    @a.Essayanswer
                </div>

                <form method="post" action="/teacher/grading/gradeessay" class="form-inline">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="answerId" value="@a.Answerid" />

                    <label class="mr-2">Điểm:</label>
                    <input type="number"
                           name="score"
                           class="form-control mr-2"
                           min="0"
                           max="@a.Marks"
                           step="0.01"
                           value="@(a.Score?.ToString("0.##") ?? "")"
                           style="width:120px;" />

                    <button class="btn btn-brand" type="submit">
                        <i class="fas fa-save"></i> Lưu điểm
                    </button>
                </form>
            }
        </div>
    </div>
}

<div class="card">
    <div class="card-body text-right">
        <form method="post" action="/teacher/grading/finalizeattempt"
              onsubmit="return confirm('Chốt điểm bài thi này? Sau khi chốt sẽ ghi kết quả cuối.');">
            @Html.AntiForgeryToken()
            <input type="hidden" name="attemptId" value="@Model.Attemptid" />
            <button class="btn btn-success" type="submit">
                <i class="fas fa-check-circle"></i> Chốt kết quả bài thi
            </button>
        </form>
    </div>
</div>