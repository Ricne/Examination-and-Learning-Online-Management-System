@model List<OMS.Models.ViewModels.Teacher.AttemptListItemVm>
@{
    var exams = ViewBag.Exams as IEnumerable<OMS.Models.Entities.Exam> ?? Array.Empty<OMS.Models.Entities.Exam>();
    int? examId = ViewBag.ExamId as int?;
    var status = ViewBag.Status as string ?? "";
}

<div class="card mb-3">
    <div class="card-body">
        <form method="get" action="/teacher/attempts/index" class="row">
            <div class="col-md-5">
                <label>Kỳ thi</label>
                <select class="form-control select2" name="examId">
                    <option value="">-- Tất cả kỳ thi --</option>
                    @foreach (var e in exams)
                    {
                        <option value="@e.Examid" selected="@(examId == e.Examid)">@e.Title</option>
                    }
                </select>
            </div>

            <div class="col-md-4">
                <label>Status</label>
                <select class="form-control" name="status">
                    <option value="">-- Tất cả status --</option>
                    <option value="submitted" selected="@(status == "submitted")">submitted</option>
                    <option value="graded" selected="@(status == "graded")">graded</option>
                    <option value="inprogress" selected="@(status == "inprogress")">inprogress</option>
                </select>
            </div>

            <div class="col-md-3 d-flex align-items-end">
                <button class="btn btn-outline-primary w-100" type="submit">
                    <i class="fas fa-filter"></i> Lọc
                </button>
            </div>
        </form>
    </div>
</div>

<div class="card">
    <div class="card-body">
        <table id="attemptTable" class="table table-hover">
            <thead>
                <tr>
                    <th style="width:90px;">Attempt</th>
                    <th>Kỳ thi</th>
                    <th style="width:220px;">Student</th>
                    <th style="width:140px;">Status</th>
                    <th style="width:170px;">Submitted</th>
                    <th style="width:110px;">Score</th>
                    <th style="width:110px;">Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var a in Model)
                {
                    <tr>
                        <td>#@a.Attemptid</td>
                        <td><b>@a.ExamTitle</b></td>
                        <td>@a.StudentName</td>
                        <td>
                            @if (a.Status == "graded")
                            {
                                <span class="badge badge-success">graded</span>
                            }
                            else if (a.Status == "submitted")
                            {
                                <span class="badge badge-warning">submitted</span>
                            }
                            else
                            {
                                <span class="badge badge-secondary">inprogress</span>
                            }
                        </td>
                        <td class="text-muted">
                            @(a.Submittime.HasValue ? a.Submittime.Value.ToString("yyyy-MM-dd HH:mm") : "-")
                        </td>
                        <td>
                            @(a.Totalscore.HasValue ? a.Totalscore.Value.ToString("0.##") : "-")
                        </td>
                        <td>
                            <a class="btn btn-sm btn-outline-primary" href="/teacher/attempts/detail?id=@a.Attemptid">
                                <i class="fas fa-eye"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        $(function(){
            $('.select2').select2({ width:'100%' });
            $('#attemptTable').DataTable({
                pageLength: 10,
                order: [[0,'desc']],
                language: {
                    search: "Tìm:",
                    lengthMenu: "Hiện _MENU_ dòng",
                    info: "Trang _PAGE_ / _PAGES_ (Tổng _TOTAL_)",
                    paginate: { previous: "Trước", next: "Sau" }
                }
            });
        });
    </script>
}