@{
    var avgFinalScore = (decimal)(ViewBag.AvgFinalScore ?? 0m);
    var topCourses = ViewBag.TopCourses as IEnumerable<dynamic> ?? Array.Empty<dynamic>();
    var latestAttempts = ViewBag.LatestAttempts as IEnumerable<dynamic> ?? Array.Empty<dynamic>();
}

@section PageActions {
    <a class="btn btn-brand" href="/teacher/questions/index">
        <i class="fas fa-database"></i> Question Bank
    </a>
    <a class="btn btn-outline-primary ml-2" href="/teacher/exams/index">
        <i class="fas fa-file-lines"></i> Đề thi
    </a>
}

<div class="row">
    <div class="col-lg-3 col-6">
        <div class="small-box bg-info">
            <div class="inner">
                <h3>@ViewBag.TotalCourses</h3>
                <p>Khóa học của tôi</p>
            </div>
            <div class="icon"><i class="fas fa-book-open"></i></div>
            <a href="/teacher/courses/index" class="small-box-footer">Xem <i class="fas fa-arrow-circle-right"></i></a>
        </div>
    </div>

    <div class="col-lg-3 col-6">
        <div class="small-box bg-success">
            <div class="inner">
                <h3>@ViewBag.ActiveCourses</h3>
                <p>Khóa học (Active)</p>
            </div>
            <div class="icon"><i class="fas fa-toggle-on"></i></div>
            <a href="/teacher/courses/index" class="small-box-footer">Quản lý <i class="fas fa-arrow-circle-right"></i></a>
        </div>
    </div>

    <div class="col-lg-3 col-6">
        <div class="small-box bg-warning">
            <div class="inner">
                <h3>@ViewBag.TotalQuestions</h3>
                <p>Câu hỏi trong bank</p>
            </div>
            <div class="icon"><i class="fas fa-circle-question"></i></div>
            <a href="/teacher/questions/index" class="small-box-footer">Mở bank <i class="fas fa-arrow-circle-right"></i></a>
        </div>
    </div>

    <div class="col-lg-3 col-6">
        <div class="small-box bg-danger">
            <div class="inner">
                <h3>@ViewBag.PendingToGrade</h3>
                <p>Bài chờ chấm</p>
            </div>
            <div class="icon"><i class="fas fa-marker"></i></div>
            <a href="/teacher/attempts/index" class="small-box-footer">Chấm bài <i class="fas fa-arrow-circle-right"></i></a>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-lg-3 col-6">
        <div class="small-box bg-primary">
            <div class="inner">
                <h3>@ViewBag.TotalExams</h3>
                <p>Tổng đề thi</p>
            </div>
            <div class="icon"><i class="fas fa-file-lines"></i></div>
            <a href="/teacher/exams/index" class="small-box-footer">Xem <i class="fas fa-arrow-circle-right"></i></a>
        </div>
    </div>

    <div class="col-lg-3 col-6">
        <div class="small-box bg-teal">
            <div class="inner">
                <h3>@ViewBag.PublishedExams</h3>
                <p>Đề đã publish</p>
            </div>
            <div class="icon"><i class="fas fa-cloud-arrow-up"></i></div>
            <a href="/teacher/exams/index" class="small-box-footer">Quản lý <i class="fas fa-arrow-circle-right"></i></a>
        </div>
    </div>

    <div class="col-lg-3 col-6">
        <div class="small-box bg-secondary">
            <div class="inner">
                <h3>@avgFinalScore.ToString("0.##")</h3>
                <p>Điểm trung bình</p>
            </div>
            <div class="icon"><i class="fas fa-star"></i></div>
            <a href="#" class="small-box-footer">Chi tiết <i class="fas fa-arrow-circle-right"></i></a>
        </div>
    </div>

    <div class="col-lg-3 col-6">
        <div class="small-box bg-olive">
            <div class="inner">
                <h3>Quick</h3>
                <p>Tạo nhanh</p>
            </div>
            <div class="icon"><i class="fas fa-bolt"></i></div>
            <a href="/teacher/questions/import" class="small-box-footer">Import Excel <i class="fas fa-arrow-circle-right"></i></a>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-lg-6">
        <div class="card">
            <div class="card-header d-flex align-items-center justify-content-between">
                <b><i class="fas fa-ranking-star mr-1"></i> Top khóa học theo số học viên</b>
                <a class="btn btn-sm btn-outline-primary" href="/teacher/courses/index">Xem tất cả</a>
            </div>
            <div class="card-body table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th style="width:70px;">ID</th>
                            <th>Khóa học</th>
                            <th style="width:120px;">Active</th>
                            <th style="width:110px;">Học viên</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!topCourses.Any())
                        {
                            <tr><td colspan="4" class="text-muted">Chưa có dữ liệu.</td></tr>
                        }
                        else
                        {
                            foreach (var c in topCourses)
                            {
                                <tr>
                                    <td>@c.Courseid</td>
                                    <td><b>@c.Coursename</b></td>
                                    <td>
                                        @if ((bool)c.Isactive)
                                        {
                                            <span class="badge badge-success">ON</span>
                                        }
                                        else
                                        {
                                            <span class="badge badge-secondary">OFF</span>
                                        }
                                    </td>
                                    <td><span class="badge badge-dark">@c.Students</span></td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="col-lg-6">
        <div class="card">
            <div class="card-header d-flex align-items-center justify-content-between">
                <b><i class="fas fa-clock mr-1"></i> Bài nộp gần đây</b>
                <span class="text-muted small">Top 10</span>
            </div>
            <div class="card-body table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th style="width:90px;">Attempt</th>
                            <th>Exam</th>
                            <th style="width:180px;">Student</th>
                            <th style="width:120px;">Status</th>
                            <th style="width:160px;">Submit</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!latestAttempts.Any())
                        {
                            <tr><td colspan="5" class="text-muted">Chưa có attempt nào.</td></tr>
                        }
                        else
                        {
                            foreach (var a in latestAttempts)
                            {
                                <tr>
                                    <td>#@a.Attemptid</td>
                                    <td><b>@a.ExamTitle</b></td>
                                    <td>@a.StudentName</td>
                                    <td>
                                        @if ((string)a.Status == "graded")
                                        {
                                            <span class="badge badge-success text-uppercase">graded</span>
                                        }
                                        else
                                        {
                                            <span class="badge badge-warning text-uppercase">submitted</span>
                                        }
                                    </td>
                                    <td class="text-muted">
                                        @(a.Submittime != null ? ((DateTime)a.Submittime).ToString("yyyy-MM-dd HH:mm") : "-")
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>