@model OMS.Models.ViewModels.Teacher.TeacherCourseEditVm

<div class="card">
    <div class="card-body">
        <form method="post" action="/teacher/courses/edit">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Courseid" />
            <input type="hidden" asp-for="Subjectid" />

            <div class="form-group">
                <label>Môn học</label>
                <input class="form-control" value="@Model.Subjectname" disabled />
                <small class="text-muted">Teacher chỉ xem môn học, không đổi môn học.</small>
            </div>

            <div class="form-group">
                <label>Tên khóa học</label>
                <input asp-for="Coursename" class="form-control" />
                <span class="text-danger" asp-validation-for="Coursename"></span>
            </div>

            <div class="form-group">
                <label>Mô tả</label>
                <textarea asp-for="Description" class="form-control" rows="5"></textarea>
            </div>

            <div class="form-check">
                <input asp-for="Isactive" class="form-check-input" />
                <label class="form-check-label">Active</label>
            </div>

            <div class="mt-4">
                <button class="btn btn-brand" type="submit">
                    <i class="fas fa-save"></i> Save
                </button>
                <a class="btn btn-outline-secondary ml-2" href="/teacher/courses/index">
                    Back
                </a>
            </div>

            <div class="text-danger mt-3">
                @Html.ValidationSummary()
            </div>
        </form>
    </div>
</div>