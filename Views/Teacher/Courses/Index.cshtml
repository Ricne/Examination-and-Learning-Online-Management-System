@model List<OMS.Models.Entities.Course>

<div class="card">
    <div class="card-body">

        <table id="teacherCourseTable" class="table table-hover">
            <thead>
                <tr>
                    <th style="width:70px;">ID</th>
                    <th>Tên khóa học</th>
                    <th style="width:180px;">Môn học</th>
                    <th style="width:100px;">Active</th>
                    <th style="width:180px;">Action</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var c in Model)
                {
                    <tr>
                        <td>@c.Courseid</td>

                        <td>
                            <b>@c.Coursename</b>

                            @if (!string.IsNullOrWhiteSpace(c.Description))
                            {
                                <div class="text-muted small"
                                     style="max-width:500px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">
                                    @c.Description
                                </div>
                            }
                        </td>

                        <td>
                            <span class="badge badge-info">
                                @c.Subject?.Subjectname
                            </span>
                        </td>

                        <td>
                            @if (c.Isactive == true)
                            {
                                <span class="badge badge-success">ON</span>
                            }
                            else
                            {
                                <span class="badge badge-secondary">OFF</span>
                            }
                        </td>

                        <td>
                            <div class="d-flex align-items-center" style="gap:10px;">

                                <a class="btn btn-sm btn-outline-primary"
                                   href="/teacher/courses/edit?id=@c.Courseid">
                                    <i class="fas fa-pen"></i> Edit
                                </a>

                                <a class="btn btn-sm btn-outline-info"
                                   href="/teacher/lessons/index?courseId=@c.Courseid">
                                    <i class="fas fa-file-lines"></i> Lessons
                                </a>

                            </div>
                        </td>
                    </tr>
                }
            </tbody>

        </table>

    </div>
</div>

@section Scripts {
    <script>
        $(function () {

            $('#teacherCourseTable').DataTable({
                pageLength: 10,
                order: [[0, 'desc']],
                language: {
                    search: "Tìm:",
                    lengthMenu: "Hiện _MENU_ dòng",
                    info: "Trang _PAGE_ / _PAGES_ (Tổng _TOTAL_)",
                    paginate: {
                        previous: "Trước",
                        next: "Sau"
                    }
                }
            });

        });
    </script>
}