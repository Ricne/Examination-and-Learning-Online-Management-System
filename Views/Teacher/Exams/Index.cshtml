@model List<OMS.Models.Entities.Exam>
@{
    var courses = ViewBag.Courses as IEnumerable<OMS.Models.Entities.Course> ?? Array.Empty<OMS.Models.Entities.Course>();
    int? courseId = ViewBag.CourseId as int?;
}

@section PageActions {
    <a class="btn btn-brand" href="/teacher/exams/create">
        <i class="fas fa-plus"></i> Tạo kỳ thi
    </a>
}

<div class="card mb-3">
    <div class="card-body">
        <form method="get" action="/teacher/exams/index" class="row">
            <div class="col-md-6">
                <label>Chọn khóa học</label>
                <select class="form-control select2" name="courseId">
                    <option value="">-- Tất cả khóa học --</option>
                    @foreach (var c in courses)
                    {
                        <option value="@c.Courseid" selected="@(courseId == c.Courseid)">
                            @c.Coursename
                        </option>
                    }
                </select>
            </div>
            <div class="col-md-3 d-flex align-items-end">
                <button class="btn btn-outline-primary w-100" type="submit">
                    <i class="fas fa-filter"></i> Lọc
                </button>
            </div>
        </form>
    </div>
</div>

<div class="card">
    <div class="card-body">
        <table id="examTable" class="table table-hover">
            <thead>
                <tr>
                    <th style="width:70px;">ID</th>
                    <th>Title</th>
                    <th style="width:180px;">Course</th>
                    <th style="width:120px;">Duration</th>
                    <th style="width:120px;">Attempts</th>
                    <th style="width:100px;">Publish</th>
                    <th style="width:100px;">Review</th>
                    <th style="width:280px;">Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var e in Model)
                {
                    <tr>
                        <td>@e.Examid</td>
                        <td>
                            <b>@e.Title</b>
                            <div class="text-muted small">
                                Total Marks: @e.Totalmarks
                            </div>
                        </td>
                        <td>@e.Course?.Coursename</td>
                        <td>@e.Durationminutes phút</td>
                        <td>@(e.Maxattempts == 0 ? "Unlimited" : e.Maxattempts.ToString())</td>
                        <td>
                            @if (e.Ispublished)
                            {
                                <span class="badge badge-success">ON</span>
                            }
                            else
                            {
                                <span class="badge badge-secondary">OFF</span>
                            }
                        </td>
                        <td>
                            @if (e.Allowreview)
                            {
                                <span class="badge badge-success">ON</span>
                            }
                            else
                            {
                                <span class="badge badge-secondary">OFF</span>
                            }
                        </td>
                        <td>
                            <a class="btn btn-sm btn-outline-info" href="/teacher/exambuilder/index?examId=@e.Examid">
                                <i class="fas fa-diagram-project"></i>
                            </a>

                            <a class="btn btn-sm btn-outline-primary ml-1" href="/teacher/exams/edit?id=@e.Examid">
                                <i class="fas fa-pen"></i>
                            </a>

                            <form method="post" action="/teacher/exams/togglepublish" class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@e.Examid" />
                                <button class="btn btn-sm btn-outline-success ml-1" type="submit">
                                    <i class="fas fa-bullhorn"></i>
                                </button>
                            </form>

                            <form method="post" action="/teacher/exams/togglereview" class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@e.Examid" />
                                <button class="btn btn-sm btn-outline-warning ml-1" type="submit">
                                    <i class="fas fa-eye"></i>
                                </button>
                            </form>

                            <form method="post" action="/teacher/exams/delete" class="d-inline"
                                  onsubmit="return confirm('Xóa đề thi này?');">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@e.Examid" />
                                <button class="btn btn-sm btn-outline-danger ml-1" type="submit">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        $(function(){
            $('.select2').select2({ width:'100%' });
            $('#examTable').DataTable({
                pageLength: 10,
                order: [[0,'desc']],
                language: {
                    search: "Tìm:",
                    lengthMenu: "Hiện _MENU_ dòng",
                    info: "Trang _PAGE_ / _PAGES_ (Tổng _TOTAL_)",
                    paginate: { previous: "Trước", next: "Sau" }
                }
            });
        });
    </script>
}